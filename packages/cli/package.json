{
  "name": "@agentlayer/cli",
  "version": "0.1.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config/loader": {
      "types": "./dist/config/loader.d.ts",
      "import": "./dist/config/loader.js"
    },
    "./config/schema": {
      "types": "./dist/config/schema.d.ts",
      "import": "./dist/config/schema.js"
    },
    "./core/memory/search": {
      "types": "./dist/core/memory/search.d.ts",
      "import": "./dist/core/memory/search.js"
    },
    "./core/memory/writer": {
      "types": "./dist/core/memory/writer.d.ts",
      "import": "./dist/core/memory/writer.js"
    }
  },
  "bin": {
    "agentlayer": "./bin/agentlayer.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@agentlayer/shared": "workspace:*",
    "@iarna/toml": "^2.2.5",
    "better-sqlite3": "^9.6.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^8.0.1",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "inquirer": "^9.3.7",
    "js-yaml": "^4.1.0",
    "ora": "^8.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/handlebars": "^4.1.0",
    "@types/inquirer": "^9.0.8",
    "@types/js-yaml": "^4.0.9",
    "tsx": "^4.0.0"
  }
}
